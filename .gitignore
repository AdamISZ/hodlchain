target/
Cargo.lock.bak
*.swp
*.swo
.DS_Store
.env
.env.local
data/

# Local IDE state — not protocol-relevant.
.claude/

# Demo scratch dir created by scripts/regtest-demo.sh — only here as a
# safety net if you ever move it inside the repo.
/tmp/hodl-regtest/

# LaTeX build artifacts + draft PDFs under docs/. Markdown docs
# and any other source files there are NOT ignored — only the
# LaTeX intermediates and the published PDFs (regenerable from .tex,
# and the .tex sources live elsewhere).
docs/*.aux
docs/*.log
docs/*.out
docs/*.synctex.gz
docs/*.toc
docs/*.pdf
docs/*.tex

# Maintainer-only notes — useful locally as a release runbook but
# not appropriate for publication (refers to maintainer by name,
# documents internal flow). Keep on disk, do not push.
docs/release.md
docs/gui-review-plan.md

# Maintainer-only macOS release-test installers. Useful for grabbing
# a CI artifact and installing it locally; not appropriate for the
# repo because they hard-code AdamISZ/hodlchain artifact naming and
# would mislead non-aarch64 / non-macOS contributors. See the
# discussion in the H3 review thread for full reasoning.
scripts/install-macos-dmg.sh
scripts/install-macos-backend.sh
